{
  "name": "@element-plus/locale",
  "version": "0.0.5",
  "description": "@element-plus/locale",
  "exports": {
    ".": {
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.js"
    },
    "./lang/*": {
      "import": "./dist/es/lang/*.mjs",
      "require": "./dist/lib/lang/*.js"
    },
    "./lang/*.js": {
      "require": "./dist/lib/lang/*.js"
    },
    "./lang/*.mjs": {
      "import": "./dist/es/lang/*.mjs"
    },
    "./*": "./*"
  },
