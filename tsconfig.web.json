{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["ES2018", "DOM", "DOM.Iterable"],

    "declaration": true,
    "emitDeclarationOnly": true,

    "jsx": "preserve",
    "jsxImportSource": "vue",

    "skipLibCheck": true
  },
  "include": [
    "typings/env.d.ts",
    "packages/components",
    "packages/constants",
    "pacakges/directives",
    "pacakges/element-plus",
    "packages/hooks",
    "packages/locale"
  ],
  "exclude": ["**/__tests__/**/*"]
}
